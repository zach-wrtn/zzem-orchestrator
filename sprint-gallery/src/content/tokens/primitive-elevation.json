{
  "wds": {
    "elevation": {
      "$type": "boxShadow",

      "none": {
        "$value": {
          "x": "0",
          "y": "0",
          "blur": "0",
          "spread": "0",
          "color": "rgba(0,0,0,0)"
        }
      },
      "xs": {
        "$value": {
          "x": "0",
          "y": "1",
          "blur": "2",
          "spread": "0",
          "color": "rgba(0,0,0,0.05)"
        }
      },
      "sm": {
        "$value": {
          "x": "0",
          "y": "2",
          "blur": "8",
          "spread": "0",
          "color": "rgba(0,0,0,0.08)"
        }
      },
      "md": {
        "$value": {
          "x": "0",
          "y": "4",
          "blur": "16",
          "spread": "0",
          "color": "rgba(0,0,0,0.12)"
        }
      },
      "lg": {
        "$value": {
          "x": "0",
          "y": "8",
          "blur": "24",
          "spread": "0",
          "color": "rgba(0,0,0,0.16)"
        }
      },
      "xl": {
        "$value": {
          "x": "0",
          "y": "16",
          "blur": "32",
          "spread": "0",
          "color": "rgba(0,0,0,0.20)"
        }
      }
    },

    "opacity": {
      "$type": "opacity",
      "0":   { "$value": "0" },
      "5":   { "$value": "0.05" },
      "10":  { "$value": "0.10" },
      "20":  { "$value": "0.20" },
      "40":  { "$value": "0.40" },
      "60":  { "$value": "0.60" },
      "80":  { "$value": "0.80" },
      "100": { "$value": "1" }
    }
  }
}
