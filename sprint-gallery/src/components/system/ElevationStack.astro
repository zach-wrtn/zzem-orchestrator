---
import { readFile } from 'node:fs/promises';
interface Props { tokenSource: string; }
const { tokenSource } = Astro.props;

interface DtcgShadow { x: string; y: string; blur: string; spread: string; color: string; }
interface ElevEntry { key: string; shadow: string; }

let levels: ElevEntry[] = [];
try {
  const raw = await readFile(`src/content/tokens/${tokenSource}`, 'utf8');
  const json = JSON.parse(raw) as Record<string, unknown>;

  // Navigate to the elevation group (wds.elevation.*)
  const wds = json['wds'] as Record<string, unknown> | undefined;
  const elevGroup = wds?.['elevation'] as Record<string, unknown> | undefined;

  if (elevGroup) {
    for (const [name, node] of Object.entries(elevGroup)) {
      if (name.startsWith('$')) continue;
      const entry = node as { $value?: DtcgShadow | string };
      if (!entry.$value) continue;
      let shadow: string;
      if (typeof entry.$value === 'string') {
        shadow = entry.$value;
      } else {
        const { x, y, blur, spread, color } = entry.$value;
        shadow = `${x}px ${y}px ${blur}px ${spread}px ${color}`;
      }
      levels.push({ key: `wds.elevation.${name}`, shadow });
    }
  }
} catch {
  // file unreadable — levels stays []
}
---
{levels.length === 0 ? (
  <p class="empty">No elevation tokens found.</p>
) : (
  <section class="stack">
    {levels.map((l) => (
      <div class="item">
        <div class="sample" style={`box-shadow: ${l.shadow};`}></div>
        <span class="k">{l.key}</span>
        <span class="v"><code>{l.shadow}</code></span>
      </div>
    ))}
  </section>
)}

<style>
  .stack { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 32px; padding: 24px 0; }
  .item { display: flex; flex-direction: column; align-items: center; gap: 12px; }
  .sample { width: 120px; height: 120px; background: var(--surface); border-radius: var(--radius-card); border: 1px solid var(--border); }
  .k { font-family: var(--font-mono); font-size: 12px; color: var(--text); }
  .v code { font-family: var(--font-mono); font-size: 10px; color: var(--text-dim); max-width: 240px; display: inline-block; text-align: center; }
  .empty { color: var(--text-dim); font-family: var(--font-mono); }
</style>
