---
import type { CollectionEntry } from 'astro:content';
interface Props {
  patterns: CollectionEntry<'patterns'>[];
  title?: string;
}
const { patterns, title = 'Used in patterns' } = Astro.props as Props;
const base = import.meta.env.BASE_URL;
---
{patterns.length > 0 && (
  <section class="ptrn">
    <header class="ptrn-head">
      <h2>{title}</h2>
      <span class="ptrn-count">{patterns.length}</span>
    </header>
    <div class="ptrn-list">
      {patterns.map((p) => (
        <a href={`${base}/system/patterns/${p.data.key}/`.replace(/\/+/g, '/')}>
          <span class="ptrn-name">{p.data.name}</span>
          <span class="ptrn-purpose">{p.data.purpose}</span>
        </a>
      ))}
    </div>
  </section>
)}

<style>
  .ptrn { margin: 32px 0; padding-top: 24px; border-top: 1px solid var(--border); }
  .ptrn-head { display: flex; align-items: baseline; gap: 12px; margin-bottom: 16px; }
  .ptrn-head h2 {
    font-size: var(--fs-h2); line-height: var(--lh-h2);
    margin: 0; color: var(--text);
  }
  .ptrn-count {
    font-family: var(--font-mono); font-size: var(--fs-label);
    letter-spacing: var(--ls-label); text-transform: uppercase;
    color: var(--text-faint); font-variant-numeric: tabular-nums;
  }
  .ptrn-list { display: grid; gap: 10px; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); }
  a {
    display: flex; flex-direction: column; gap: 4px;
    padding: 14px 16px;
    background: var(--surface);
    border: 1px solid var(--border); border-radius: var(--radius-card);
    transition: border-color var(--dur-ui) var(--ease-out-quart),
                transform var(--dur-spring-soft) var(--spring-soft);
  }
  a:hover { border-color: var(--accent); transform: translateY(-2px); }
  .ptrn-name { font-weight: 600; color: var(--text); font-size: var(--fs-small); }
  .ptrn-purpose {
    font-size: 12px; color: var(--text-dim); line-height: 1.5;
    overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
  }
</style>
